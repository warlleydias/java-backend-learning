<project xmlns="http://maven.apache.org/POM/4.0.0" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.warlley</groupId>
  <artifactId>meu-primeiro-maven</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <name>Projeto de Orientação a Objetos - UnB</name>
  <description>Exercícios da matéria de POO utilizando Java 21 e Maven para gestão de dependências.</description>

  <properties>
    <maven.compiler.source>21</maven.compiler.source>
    <maven.compiler.target>21</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <org.projectlombok.version>1.5.5Final</org.projectlombok.version>
  </properties>
  
<dependencies>
    <dependency>
        <groupId>org.mapstruct</groupId>
        <artifactId>mapstruct</artifactId>
        <version>${org.projectlombok.version}</version>
    </dependency>

    <dependency>
        <groupId>org.mapstruct</groupId>
        <artifactId>mapstruct-processor</artifactId>
        <version>${org.projectlombok.version}</version>
        <scope>provided</scope> 
    </dependency>
</dependencies>
  

</project>